# Production environment variables - CONFIGURE FOR YOUR DEPLOYMENT
# Copy this to .env.production (Netlify will auto-detect and use it)

# Backend API URL - REPLACE WITH YOUR RENDER BACKEND URL
# Format: https://your-service-name.onrender.com
REACT_APP_API_BASE_URL=https://YOUR_RENDER_SERVICE_URL.onrender.com
REACT_APP_API_URL=https://YOUR_RENDER_SERVICE_URL.onrender.com/api
